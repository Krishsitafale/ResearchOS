   "source": [
    "import numpy as np\n",
    "\n",
    "# Inputs\n",
    "X = np.array([2.0, 3.0])\n",
    "\n",
    "# Weights\n",
    "W = np.array([0.5, 0.8])\n",
    "\n",
    "# Bias\n",
    "b = 0.2\n",
    "\n",
    "# Weighted Sum\n",
    "z = np.dot(X, W) + b\n",
    "\n",
    "# ReLU Activation\n",
    "a = max(0, z)\n",
    "\n",
    "print(\"Weighted Sum:\", z)\n",
    "print(\"Neuron Output:\", a)"
   ]
  },
